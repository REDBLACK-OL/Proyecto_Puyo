generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Tabla Usuario: Almacena administradores, docentes y estudiantes con su DNI, rol y turno asignado
model Usuario {
  id          Int          @id @default(autoincrement())
  dni         String       @unique
  nombres     String       @db.VarChar(150)
  password    String?      @db.VarChar(255)
  rol         String       @default("USER") @db.VarChar(20)  // ADMIN o USER
  turno       String       @db.VarChar(20)                   // MANANA o TARDE
  fecha       DateTime     @default(now())
  
  incidencias Incidencia[]

  @@index([fecha])
}

// 2. Tabla Incidencia: Guarda los reportes técnicos, sus evidencias (fotos en servidor), aula y estado del semáforo
model Incidencia {
  id            Int       @id @default(autoincrement())
  titulo        String    @db.VarChar(200)
  descripcion   String
  aula          String    @db.VarChar(50)
  estado        String    @default("Pendiente") @db.VarChar(30)
  imagen        String?   // Rutas o URLs separadas por coma
  fecha         DateTime  @default(now())
  fechaSolucion DateTime?
  
  usuarioId     Int
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  // Índices obligatorios según Regla 4 (Patrones PostgreSQL)
  @@index([usuarioId])                   // Evita Sequential Scan en joins y verificaciones de FK
  @@index([estado, fechaSolucion])       // Optimiza limpieza automática (Cron de 24 hrs)
  @@index([fecha])                       // Optimiza ordenamiento descendente en listados
}

// 3. Tabla Ubicacion: Laboratorios y ambientes dinámicos gestionables por el Administrador sin editar código
model Ubicacion {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique @db.VarChar(100)
  activo    Boolean  @default(true)
  fecha     DateTime @default(now())

  // Índice obligatorio para búsquedas rápidas al cargar selector
  @@index([activo, nombre])
}

// 4. Tabla Notificacion: Registro histórico de alertas en tiempo real para encender el globo rojo de la campanita en el Navbar
model Notificacion {
  id           Int       @id @default(autoincrement())
  titulo       String    @db.VarChar(200)
  mensaje      String
  tipo         String    @default("INCIDENCIA") @db.VarChar(30)
  leido        Boolean   @default(false)
  incidenciaId Int?
  fecha        DateTime  @default(now())

  // Índices obligatorios según Regla 4 (Patrones PostgreSQL)
  @@index([leido, fecha])
  @@index([incidenciaId])
}

