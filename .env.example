# ==============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO (.env.example)
# Copia este archivo y renómbralo a exactamente .env en la raíz de tu proyecto.
# Reemplaza los valores con tus credenciales locales de PostgreSQL.
# ==============================================================================

# Reemplaza "tu_usuario" y "tu_contraseña" por tu usuario (ej: postgres) y clave en pgAdmin/PostgreSQL
# Reemplaza "incidencias_suiza" por el nombre de la base de datos que creaste en pgAdmin
DATABASE_URL="postgresql://tu_usuario:tu_contraseña@localhost:5432/incidencias_suiza?schema=public"

# Clave secreta para firmar y verificar sesiones (cookie JWT)
JWT_SECRET="clave_secreta_super_segura_suiza_2026"
